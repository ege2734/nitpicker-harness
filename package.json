{
  "name": "nitpicker-harness",
  "version": "0.1.0",
  "description": "Standalone same-origin proxy harness: point it at a running web app and get the full in-app feedback overlay — region screenshots, element→component/selector/source, chat/queue → sidecar — with zero overlay code in the target's repo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ege2734/nitpicker-harness"
  },
  "type": "module",
  "bin": {
    "nitpicker-harness": "bin/nitpicker-harness"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "vendor",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "nitpicker",
    "claude",
    "claude-code",
    "agent-skill",
    "feedback",
    "overlay",
    "reverse-proxy",
    "react",
    "nextjs",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "prepare": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "prepack": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "harness": "tsx src/cli.ts",
    "poll": "tsx src/cli.ts poll",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify-pack": "bash scripts/verify-pack.sh"
  },
  "dependencies": {
    "http-proxy": "^1.18.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "html2canvas-pro": "^2.2.3",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215"
  }
}
