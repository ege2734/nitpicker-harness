{
  "name": "nitpicker-harness",
  "version": "0.1.0",
  "description": "Standalone same-origin proxy harness: point it at a running web app and get the full in-app feedback overlay — region screenshots, element→component/selector/source, chat/queue → sidecar — with zero overlay code in the target's repo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ege2734/nitpicker-harness"
  },
  "type": "module",
  "bin": {
    "nitpicker-harness": "bin/nitpicker-harness"
  },
  "files": [
    "bin",
    "src",
    "vendor",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "nitpicker",
    "claude",
    "claude-code",
    "agent-skill",
    "feedback",
    "overlay",
    "reverse-proxy",
    "react",
    "nextjs",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "harness": "tsx src/cli.ts",
    "poll": "tsx src/cli.ts poll",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "esbuild": "^0.24.0",
    "html2canvas": "^1.4.1",
    "http-proxy": "^1.18.1",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
